# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI
OPENAI_API_KEY=

# Gmail OAuth (Google Cloud Console -> OAuth 2.0 Client ID, type "Web application")
# Authorized redirect URI must be: <your-deployed-origin>/api/auth/gmail/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Cron
CRON_SECRET=

# Sentry error tracking (optional — errors just aren't reported if unset,
# nothing else breaks). Create a project at sentry.io to get these.
# NEXT_PUBLIC_SENTRY_DSN and SENTRY_DSN should be the same value — one is
# read client-side, the other server-side.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Only needed if you want source maps uploaded on build (better stack
# traces in Sentry) — an org-scoped auth token from sentry.io/settings/auth-tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
